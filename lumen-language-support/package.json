{
  "name": "lumen-language-support",
  "displayName": "Lumen Language Support",
  "description": "Language support for Lumen",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.109.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "contributes": {
    "languages": [{
      "id": "lumen",
      "aliases": ["Lumen", "lumen"],
      "extensions": [".lm"],
      "configuration": "./language-configuration.json"
    }],
    "grammars": [{
      "language": "lumen",
      "scopeName": "source.lumen",
      "path": "./syntaxes/lumen.tmLanguage.json"
    }]
  }
}
