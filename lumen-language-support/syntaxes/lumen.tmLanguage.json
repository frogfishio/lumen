{
	"$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
	"name": "Lumen",
	"patterns": [
		{ "include": "#comments" },
		{ "include": "#strings" },
		{ "include": "#chars" },
		{ "include": "#numbers" },
		{ "include": "#attributes" },
		{ "include": "#declarations" },
		{ "include": "#paths" },
		{ "include": "#types" },
		{ "include": "#operators" },
		{ "include": "#keywords" }
	],
	"repository": {
		"comments": {
			"patterns": [
				{ "include": "#line-comment" },
				{ "include": "#block-comment" }
			]
		},
		"line-comment": {
			"name": "comment.line.double-slash.lumen",
			"match": "//.*$"
		},
		"block-comment": {
			"name": "comment.block.lumen",
			"begin": "/\\*",
			"end": "\\*/",
			"patterns": [
				{ "include": "#block-comment" }
			]
		},
		"strings": {
			"patterns": [
				{ "include": "#raw-string" },
				{ "include": "#bytes-string" },
				{ "include": "#cstr-string" },
				{ "include": "#cooked-string" }
			]
		},
		"cooked-string": {
			"name": "string.quoted.double.lumen",
			"begin": "\"",
			"beginCaptures": {
				"0": { "name": "punctuation.definition.string.begin.lumen" }
			},
			"end": "\"",
			"endCaptures": {
				"0": { "name": "punctuation.definition.string.end.lumen" }
			},
			"patterns": [
				{
					"name": "constant.character.escape.lumen",
					"match": "\\\\(x[0-9A-Fa-f]{2}|u\\{[0-9A-Fa-f_]+\\}|.)"
				}
			]
		},
		"raw-string": {
			"name": "string.quoted.double.raw.lumen",
			"begin": "\\b(r)(\")",
			"beginCaptures": {
				"1": { "name": "storage.type.string.lumen" },
				"2": { "name": "punctuation.definition.string.begin.lumen" }
			},
			"end": "\"",
			"endCaptures": {
				"0": { "name": "punctuation.definition.string.end.lumen" }
			}
		},
		"bytes-string": {
			"name": "string.quoted.double.bytes.lumen",
			"begin": "\\b(b)(\")",
			"beginCaptures": {
				"1": { "name": "storage.type.string.lumen" },
				"2": { "name": "punctuation.definition.string.begin.lumen" }
			},
			"end": "\"",
			"endCaptures": {
				"0": { "name": "punctuation.definition.string.end.lumen" }
			},
			"patterns": [
				{
					"name": "constant.character.escape.lumen",
					"match": "\\\\(x[0-9A-Fa-f]{2}|u\\{[0-9A-Fa-f_]+\\}|.)"
				}
			]
		},
		"cstr-string": {
			"name": "string.quoted.double.cstr.lumen",
			"begin": "\\b(c)(\")",
			"beginCaptures": {
				"1": { "name": "storage.type.string.lumen" },
				"2": { "name": "punctuation.definition.string.begin.lumen" }
			},
			"end": "\"",
			"endCaptures": {
				"0": { "name": "punctuation.definition.string.end.lumen" }
			},
			"patterns": [
				{
					"name": "constant.character.escape.lumen",
					"match": "\\\\(x[0-9A-Fa-f]{2}|u\\{[0-9A-Fa-f_]+\\}|.)"
				}
			]
		},
		"chars": {
			"name": "string.quoted.single.lumen",
			"begin": "'",
			"beginCaptures": {
				"0": { "name": "punctuation.definition.string.begin.lumen" }
			},
			"end": "'",
			"endCaptures": {
				"0": { "name": "punctuation.definition.string.end.lumen" }
			},
			"patterns": [
				{
					"name": "constant.character.escape.lumen",
					"match": "\\\\(x[0-9A-Fa-f]{2}|u\\{[0-9A-Fa-f_]+\\}|.)"
				}
			]
		},
		"numbers": {
			"patterns": [
				{
					"name": "constant.numeric.float.hex.lumen",
					"match": "\\b0[xX][0-9A-Fa-f_]+(?:\\.[0-9A-Fa-f_]+)?[pP][+-]?[0-9][0-9_]*\\b"
				},
				{
					"name": "constant.numeric.float.lumen",
					"match": "\\b(?:[0-9][0-9_]*\\.[0-9][0-9_]*(?:[eE][+-]?[0-9][0-9_]*)?|[0-9][0-9_]*[eE][+-]?[0-9][0-9_]*)\\b"
				},
				{
					"name": "constant.numeric.integer.hex.lumen",
					"match": "\\b0[xX][0-9A-Fa-f_]+\\b"
				},
				{
					"name": "constant.numeric.integer.binary.lumen",
					"match": "\\b0[bB][01_]+\\b"
				},
				{
					"name": "constant.numeric.integer.decimal.lumen",
					"match": "\\b[0-9][0-9_]*\\b"
				}
			]
		},
		"attributes": {
			"patterns": [
				{
					"name": "meta.annotation.lumen",
					"match": "(@)([A-Za-z_][A-Za-z0-9_]*)",
					"captures": {
						"1": { "name": "punctuation.definition.annotation.lumen" },
						"2": { "name": "entity.name.function.attribute.lumen" }
					}
				}
			]
		},
		"declarations": {
			"patterns": [
				{
					"name": "meta.function.lumen",
					"match": "\\b(unsafe)\\s+(fn)\\s+([A-Za-z_][A-Za-z0-9_]*)\\b",
					"captures": {
						"1": { "name": "keyword.other.unsafe.lumen" },
						"2": { "name": "keyword.declaration.function.lumen" },
						"3": { "name": "entity.name.function.lumen" }
					}
				},
				{
					"name": "meta.function.lumen",
					"match": "\\b(fn)\\s+([A-Za-z_][A-Za-z0-9_]*)\\b",
					"captures": {
						"1": { "name": "keyword.declaration.function.lumen" },
						"2": { "name": "entity.name.function.lumen" }
					}
				},
				{
					"name": "meta.type.declaration.lumen",
					"match": "\\b(enum|struct|union|trait|type)\\s+([A-Za-z_][A-Za-z0-9_]*)\\b",
					"captures": {
						"1": { "name": "keyword.declaration.type.lumen" },
						"2": { "name": "entity.name.type.lumen" }
					}
				},
				{
					"name": "meta.macro.lumen",
					"match": "\\b(macro)\\s+([A-Za-z_][A-Za-z0-9_]*)\\b",
					"captures": {
						"1": { "name": "keyword.declaration.macro.lumen" },
						"2": { "name": "entity.name.function.macro.lumen" }
					}
				},
				{
					"name": "meta.module.lumen",
					"match": "\\b(mod)\\s+([A-Za-z_][A-Za-z0-9_:]*)\\b",
					"captures": {
						"1": { "name": "keyword.declaration.module.lumen" },
						"2": { "name": "entity.name.namespace.lumen" }
					}
				},
				{
					"name": "meta.variable.declaration.lumen",
					"match": "\\b(let)\\s+(mut\\s+)?([A-Za-z_][A-Za-z0-9_]*)\\b",
					"captures": {
						"1": { "name": "keyword.declaration.variable.lumen" },
						"2": { "name": "storage.modifier.mut.lumen" },
						"3": { "name": "variable.other.definition.lumen" }
					}
				}
			]
		},
		"paths": {
			"patterns": [
				{
					"name": "support.namespace.lumen",
					"match": "\\b(?:self|super|crate|[A-Za-z_][A-Za-z0-9_]*)(?:::[A-Za-z_][A-Za-z0-9_]*)+\\b"
				}
			]
		},
		"types": {
			"patterns": [
				{
					"name": "support.type.primitive.lumen",
					"match": "\\b(?:I8|I16|I32|I64|Isize|U8|U16|U32|U64|Usize|F32|F64|Bool|Char|String|Ptr|Never|Unit|i8|i16|i32|i64|isize|u8|u16|u32|u64|usize|f32|f64|bool|char|string|ptr)\\b"
				},
				{
					"name": "entity.name.type.lumen",
					"match": "\\b[A-Z][A-Za-z0-9_]*\\b"
				}
			]
		},
		"operators": {
			"patterns": [
				{
					"name": "keyword.operator.lumen",
					"match": "\\.\\.\\.|\\.\\.|::|=>|->|==|!=|<=|>=|<<|>>|\\|\\||&&|[+\\-*/%&|\\^~!<>?=]"
				}
			]
		},
		"keywords": {
			"patterns": [
				{
					"name": "constant.language.boolean.lumen",
					"match": "\\b(true|false)\\b"
				},
				{
					"name": "variable.language.lumen",
					"match": "\\b(self|super|crate)\\b"
				},
				{
					"name": "constant.language.underscore.lumen",
					"match": "\\b_\\b"
				},
				{
					"name": "keyword.control.lumen",
					"match": "\\b(if|else|match|try|return|while|loop|break|continue|for|in|defer)\\b"
				},
				{
					"name": "keyword.other.lumen",
					"match": "\\b(fn|unsafe|extern|let|mut|where|trait|impl|enum|struct|union|use|as|pub|static|const|type|macro|test|asm|out|clobber|options)\\b"
				}
			]
		}
	},
	"scopeName": "source.lumen"
}