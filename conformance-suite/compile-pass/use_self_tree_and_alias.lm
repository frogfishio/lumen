use self::{Inner as Renamed, mk};

pub struct PubType { x: I32 }
struct PrivType { y: I32 }

pub fn make() -> PubType { PubType { x: 1 as I32 } }

struct Inner { z: I32 }
fn mk() -> Inner { Inner { z: 2 as I32 } }

fn main() {
  let a: PubType = make();
  let b: Renamed = mk();
  let _ = a.x;
  let _ = b.z;
}
