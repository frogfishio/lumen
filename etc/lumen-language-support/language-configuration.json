{
    "comments": {
        "lineComment": "//",
        "blockComment": [ "/*", "*/" ]
    },
    "brackets": [
        ["{", "}"],
        ["[", "]"],
        ["(", ")"]
    ],
    "colorizedBracketPairs": [
        ["{", "}"],
        ["[", "]"],
        ["(", ")"]
    ],
    "autoClosingPairs": [
        { "open": "{", "close": "}" },
        { "open": "[", "close": "]" },
        { "open": "(", "close": ")" },
        { "open": "\"", "close": "\"", "notIn": ["string", "comment"] },
        { "open": "'", "close": "'", "notIn": ["string", "comment"] },
        { "open": "/*", "close": "*/", "notIn": ["string"] }
    ],
    "surroundingPairs": [
        { "open": "{", "close": "}" },
        { "open": "[", "close": "]" },
        { "open": "(", "close": ")" },
        { "open": "\"", "close": "\"" },
        { "open": "'", "close": "'" }
    ],
    "autoCloseBefore": ";:.,=}])> \n\t",
    "wordPattern": "(-?\\d[\\d_]*(?:\\.[\\d_]+)?(?:[eE][+-]?\\d[\\d_]*)?|0[xX][0-9A-Fa-f_]+(?:\\.[0-9A-Fa-f_]+)?[pP][+-]?\\d[\\d_]*|0[bB][01_]+)|([A-Za-z_][A-Za-z0-9_]*)",
    "indentationRules": {
        "increaseIndentPattern": "^.*(\\{[^\"']*|\\([^\"']*|\\[[^\"']*)$",
        "decreaseIndentPattern": "^\\s*[}\\)\\]].*$"
    },
    "folding": {
        "offSide": false,
        "markers": {
            "start": "^\\s*//\\s*#?region\\b",
            "end": "^\\s*//\\s*#?endregion\\b"
        }
    }
}