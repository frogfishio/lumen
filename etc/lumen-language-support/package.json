{
  "name": "lumen-language-support",
  "displayName": "Lumen Language Support",
  "description": "Syntax highlighting, snippets, and editor configuration for the Lumen programming language",
  "version": "0.1.0",
  "publisher": "lumen-lang",
  "engines": {
    "vscode": "^1.109.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "contributes": {
    "languages": [{
      "id": "lumen",
      "aliases": ["Lumen", "lumen"],
      "extensions": [".lm"],
      "configuration": "./language-configuration.json"
    }],
    "grammars": [{
      "language": "lumen",
      "scopeName": "source.lumen",
      "path": "./syntaxes/lumen.tmLanguage.json"
    }],
    "snippets": [
      {
        "language": "lumen",
        "path": "./snippets/lumen.json"
      }
    ]
  },
  "license": "GPL-3.0-or-later",
  "author": "Alexander R. Croft <alex@frogfish.io>"
}
