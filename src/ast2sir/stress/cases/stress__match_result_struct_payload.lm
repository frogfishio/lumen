// Stress: match over Result with nested struct payload pattern.

struct Pair { a: I32, b: I32 }

fn mk(x: I32) -> Result[Pair, I32] {
  if x == (0 as I32) {
    Err(9 as I32)
  } else {
    Ok(Pair { a: x, b: x + (1 as I32) })
  }
}

fn get_a(r: Result[Pair, I32]) -> I32 {
  match r {
    Ok(Pair { a, .. }) => a,
    Err(e) => e,
  }
}

fn main() {
  let r1: Result[Pair, I32] = mk(1 as I32);
  let r2: Result[Pair, I32] = mk(0 as I32);
  let _x: I32 = get_a(r1);
  let _y: I32 = get_a(r2);
}
