fn main() {
    let arr = [1, 2, 3];
    let mut sum = 0 as I32;
    for item in arr {
        unsafe {
            defer {
                sum = sum + 1;
            };
            sum = sum + item;
        }
    }
    match sum {
        0 => {}
        _ => {
            let _ = sum;
        }
    }
}