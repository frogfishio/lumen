struct Complex {
    a: I32,
    b: I32,
    c: I32,
    d: I32,
    e: I32,
}

fn main() {
    let s = Complex { a: 1 as I32, b: 2 as I32, c: 3 as I32, d: 4 as I32, e: 5 as I32 };
    let updated = Complex { b: 10 as I32, ..s };
    let _ = updated.a + updated.b + updated.c + updated.d + updated.e;
}