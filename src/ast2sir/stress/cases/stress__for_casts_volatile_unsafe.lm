extern "C" fn puts(s: Ptr[U8]);

static mut VOLATILE_VAR: I32 = 0;

fn main() {
    let arr = [1, 2, 3, 4, 5];
    let mut sum = 0 as I32;

    for item in arr {
        unsafe {
            sum = sum + item;
            let casted = sum as Usize;
            let back = casted as I32;
            sum = back * 2;

            VOLATILE_VAR = sum;
            let loaded = VOLATILE_VAR;

            let _ = loaded;
        }
    }
}