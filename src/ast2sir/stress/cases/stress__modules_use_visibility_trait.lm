trait Inc {
  fn inc(x: Self) -> Self;
}

impl Inc for I32 {
  fn inc(x: I32) -> I32 { x + (1 as I32) }
}

pub struct PubType { x: I32 }

pub fn make() -> PubType { PubType { x: 1 as I32 } }

mod inner {
  pub fn f() -> I32 { 2 as I32 }
}

fn main() -> I32 {
  let p: PubType = make();
  let a: I32 = Inc.inc(p.x);
  let b: I32 = inner::f();
  let _ = a + b;
  0 as I32
}
