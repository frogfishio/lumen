// Local extra conformance fixture (not part of the upstream suite):
// Minimal "hello world" that exercises bytes literal lowering + unsafe FFI call.

extern "C" unsafe fn write(fd: I32, buf: Ptr[U8], len: I32) -> I32;

fn main() {
  unsafe {
    let msg: Ptr[U8] = (b"hello world\n" as Ptr[U8]);
    let _rc = write(1 as I32, msg, 12 as I32);
  }
}
