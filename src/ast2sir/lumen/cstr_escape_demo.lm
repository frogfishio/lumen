// Demonstrate cooked vs literal-backslash CStr at the surface level.
// Lumen supports raw UTF-8 strings (`r"..."`), but currently CStr literals are `c"..."` (cooked).
// So to get a literal backslash+n into a CStr, we write `\\n`.

extern "C" unsafe fn puts(s: CStr) -> I32;

fn main() {
  unsafe {
    let _a = puts(c"cooked: line1\nline2");
    let _b = puts(c"literal: line1\\nline2");
  }
}
