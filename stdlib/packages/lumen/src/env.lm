mod lumen::env;

// Environment access.
//
// Note: these APIs operate on C strings (NUL-terminated `Ptr[U8]`) and return
// pointers owned by the host process.

extern "C" unsafe fn lf_getenv(name: Usize) -> Usize;

pub unsafe fn getenv(name: Ptr[U8]) -> Option[Ptr[U8]] {
	let v = lf_getenv(name as Usize);
	if v == 0 as Usize {
		Option::None
	} else {
		Option::Some(v as Ptr[U8])
	}
}

pub unsafe fn isset(name: Ptr[U8]) -> bool {
	lf_getenv(name as Usize) != 0 as Usize
}