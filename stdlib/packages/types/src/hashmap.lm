pub fn free_map(m: HashMap) -> HashMap {
	if m == U0 {
		return U0;
	}
	unsafe {
		let keys: Usize = _load_usize(_hdr_addr(m, HDR_KEYS));
		let vals: Usize = _load_usize(_hdr_addr(m, HDR_VALS));
		let states: Usize = _load_usize(_hdr_addr(m, HDR_STATES));
		let _ = free(keys);
		let _ = free(vals);
		let _ = free(states);
		let _ = free(m);
		U0
	}
}

