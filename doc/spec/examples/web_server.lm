// Explicit runtime polymorphism (C-style vtable).

@repr(C)
struct WriterVTable {
  write: fn(ctx: Ptr[Void], bytes: Slice[U8]) -> Usize,
}

@repr(C)
struct Writer {
  ctx: Ptr[Void],
  v: Ptr[WriterVTable],
}

unsafe fn writerWrite(w: Writer, bytes: Slice[U8]) -> Usize {
  (*w.v).write(w.ctx, bytes)
}
