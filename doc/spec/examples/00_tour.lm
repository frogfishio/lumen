// A quick tour of Lumen (core profile)

enum Result[T, E] { Ok(T), Err(E) }

enum DivError { DivByZero }

fn div(a: I32, b: I32) -> Result[I32, DivError] {
  if b == 0 { Err(DivByZero) } else { Ok(a / b) }
}

fn demo() -> Result[I32, DivError] {
  defer { /* scope-exit cleanup lives here */ }
  let x = try div(42, 2)
  let y = try div(x, 0)
  Ok(y)
}

fn main() {
  let _ = demo()
}
