extern "C" unsafe fn strlen(s: Ptr[U8]) -> Usize;

fn main() {
  unsafe {
    let z0: Usize = 0 as Usize;
    let fmt: Ptr[U8] = (z0 as Ptr[U8]);

    // varargs widening + ptr/int casts
    let _rc: I32 = printf(fmt, 1 as I32, (2 as Usize) as Ptr[U8], 3 as U64, 4 as I8);

