// Stress: match over Result with nested struct payload pattern.

enum ResultPairI32 {
  Ok(Pair),
  Err(I32)
}

struct Pair { a: I32, b: I32 }

fn mk(x: I32) -> ResultPairI32 {
  if x == (0 as I32) {
    Err(9 as I32)
  } else {
    Ok(Pair { a: x, b: x + (1 as I32) })
  }
}

fn get_a(r: ResultPairI32) -> I32 {
  let rr: ResultPairI32 = r;
  match rr {
    Ok(Pair { a, .. }) => a,
    Err(e) => e,
  }
}

fn main() {
  let r1: ResultPairI32 = mk(1 as I32);
  let r2: ResultPairI32 = mk(0 as I32);
  let _x: I32 = get_a(r1);
  let _y: I32 = get_a(r2);
}
