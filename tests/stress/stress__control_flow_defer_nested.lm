fn main() {
  let mut i: I32 = 0;
  let mut acc: I32 = 0;

  loop {
    defer { i = i + (1 as I32); }
    {
      defer { acc = acc + (10 as I32); }

      if i == 0 {
        continue;
      }

      if i == 1 {
        acc = acc + (1 as I32);
      } else {
        acc = acc + (2 as I32);
      }
    }

    break;
  }

  let _ = i;
  let _ = acc;
}
