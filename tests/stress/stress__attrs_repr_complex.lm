@repr(C)
@align(8)
struct ComplexStruct {
    a: I32,
    b: I64,
}

@no_mangle
@visibility("default")
extern "C" fn external_func(x: I32) -> I32 {
    x
}

fn main() {
    let s = ComplexStruct { a: 1 as I32, b: 2 as I64 };
    unsafe {
        let res = external_func(s.a);
        let _ = res;
    }
}